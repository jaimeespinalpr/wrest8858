rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdminEmail() {
      return signedIn()
        && request.auth.token.email != null
        && request.auth.token.email == "gmunch@united-wc.com";
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isSelfAllowedRole(role) {
      return role == "athlete" || role == "coach" || role == "parent";
    }

    function isAdminAllowedRole(role) {
      return isSelfAllowedRole(role) || role == "admin";
    }

    // User profiles: self-manage + global admin access for account administration.
    match /users/{uid} {
      allow read: if isSelf(uid) || isAdminEmail();
      allow create, update: if (
        isAdminEmail() && isAdminAllowedRole(request.resource.data.role)
      ) || (
        isSelf(uid) && isSelfAllowedRole(request.resource.data.role)
      );
      allow delete: if isAdminEmail();
    }

    // Shared media tree is collaborative between authenticated users.
    match /shared_app/{docId} {
      allow read, write: if signedIn();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
