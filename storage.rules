rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    match /media_uploads/{uid}/{allPaths=**} {
      allow read, write: if 
        isSignedIn() && 
        request.auth.uid == uid &&
        request.resource.contentType.matches('image/.*|video/.*|audio/.*') &&
        request.resource.size < 100 * 1024 * 1024;
    }
  }
}
